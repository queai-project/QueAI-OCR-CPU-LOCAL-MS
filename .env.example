# ==========================================
# PROJECT
# ==========================================
PROJECT_NAME="OCR Local CPU"
PROJECT_SLUG="ocr_local_cpu"
VERSION="1.1.4"
ENVIRONMENT="development"
CORS_ORIGINS=["*"]

# Base pública única
BASE_PATH="/api/ocr_local_cpu"

# ==========================================
# SERVER
# ==========================================
API_HOST="0.0.0.0"
API_PORT=8000

# ==========================================
# AUTH
# ==========================================
API_KEY="pon_aqui_una_clave_larga_y_secreta"

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL="INFO"
LOG_FORMAT="%(asctime)s - %(name)s - %(levelname)s - %(message)s"
LOG_DATETIME_FORMAT="%Y-%m-%d %H:%M:%S"
LOG_DIR="logs"
LOG_FILENAME="ocr_local_cpu.log"

# ==========================================
# PLUGIN META
# ==========================================
DISPLAY_NAME="OCR Local CPU"
DESCRIPTION="Módulo OCR oficial para QueAI. Imagen a texto de alta fidelidad basado en Tesseract. Ejecución local en CPU."
AUTHOR="Alejandro Fonseca && Juana Iris"
LICENSE="MIT"
LOGO="ocr_logo.png"

# ==========================================
# REDIS / JOBS
# ==========================================
REDIS_URL="redis://redis:6379/0"
RQ_QUEUE_NAME="ocr"
JOB_TIMEOUT_SECONDS=1800
JOB_RESULT_TTL_SECONDS=3600
JOB_FAILURE_TTL_SECONDS=3600
JOB_TTL_SECONDS=3600
JOB_MAX_RETRIES=1
JOB_RETRY_INTERVAL_SECONDS=10
EVENT_TTL_SECONDS=3600

# ==========================================
# WORKSPACE
# ==========================================
WORKSPACE_ROOT="/tmp/ocr-jobs"
TEMP_WORKSPACE_TTL_HOURS=24
MAX_UPLOAD_SIZE_MB=25
MAX_PDF_PAGES=50

ALLOWED_EXTENSIONS=["pdf","png","jpg","jpeg","tif","tiff","webp"]
ALLOWED_MIME_TYPES=["application/pdf","image/png","image/jpeg","image/tiff","image/webp"]

# ==========================================
# SSE / DEBUG
# ==========================================
SSE_PING_SECONDS=10
DEBUG_SAVE_OCR_ARTIFACTS=false
DEBUG_KEEP_WORKSPACE=false

# ==========================================
# OCR
# ==========================================
OCR_ENGINE="tesseract"
OCR_LANG="spa+eng"
PDF_RENDER_DPI=200
PDFINFO_TIMEOUT_SECONDS=15
PDFTOPPM_TIMEOUT_SECONDS=180
TESSERACT_TIMEOUT_SECONDS=180
TESSERACT_PSM=3
TESSERACT_OEM=1